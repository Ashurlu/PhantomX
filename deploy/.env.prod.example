# Copy to repo root as .env.prod and fill in before deploying.
#   cp deploy/.env.prod.example .env.prod

# REQUIRED — long random string (openssl rand -hex 32)
JWT_SECRET=replace-with-a-long-random-secret

# Public URL users open in the browser (http://DROPLET_IP or https://your.domain)
PUBLIC_URL=http://YOUR_DROPLET_IP

# mock = demo JSON data | live = real n8n/pentest upstreams
DATA_SOURCE=mock

# ProtonRed AD pentest engine is bundled in docker-compose (pentest-engine service).
# For local dev without Docker, run proton-red and set Admin → API Keys → Pentest URL.
# PENTEST_BASE_URL=http://localhost:8001

# Host port for the app when NOT using the https profile (default 80)
HTTP_PORT=80

# --- Optional HTTPS (docker compose --profile https) ---
# DOMAIN=sentrix.example.com
# ACME_EMAIL=you@example.com
# PUBLIC_URL=https://sentrix.example.com
