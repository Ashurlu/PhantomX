# PhantomX / SENTRIX backend configuration
APP_NAME=SENTRIX
DATA_SOURCE=mock
JWT_SECRET=change-me-in-production-super-secret-key
JWT_ALG=HS256
JWT_EXPIRE_MINUTES=480
CORS_ORIGINS=http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173

# LATER (live mode) — never exposed to frontend
N8N_BASE_URL=
N8N_API_KEY=
PENTEST_BASE_URL=
PENTEST_API_KEY=

# Web Pentest Agent (AGI Pentest → Web Scan tab)
# Option A — embedded in this backend (leave WEB_PENTEST_URL empty):
#   pip install pyyaml httpx
#   Set AI_PROVIDER + API key below, restart uvicorn on port 8000
# Option B — standalone agent on port 18000:
#   cd pentest-agent/backend && python main.py
#   WEB_PENTEST_URL=http://127.0.0.1:18000
WEB_PENTEST_URL=
AI_PROVIDER=local_mock
AI_MODEL=
GROQ_API_KEY=
OPENROUTER_API_KEY=
ALLOW_PRIVATE_IPS=false
